{
  "name": "claudelens-app",
  "version": "1.0.0",
  "description": "ClaudeLens — GUI for Claude Code data",
  "author": "Giulio Di Giamberardino",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "preview": "vite preview",
    "electron:build": "electron-builder",
    "memory-stats": "npx ts-node ../scripts/memory-stats.ts",
    "screenshot": "SCREENSHOT_MODE=true concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\""
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "chokidar": "^3.6.0",
    "glob": "^10.4.1",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-query": "^3.39.3",
    "recharts": "^3.8.0",
    "rehype-highlight": "^7.0.2",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vite-plugin-electron": "^0.28.7",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.claudelens.app",
    "productName": "ClaudeLens",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "icon4.icns"
    ],
    "mac": {
      "target": "dmg",
      "icon": "./icon4.icns"
    }
  }
}